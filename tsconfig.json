{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "types": ["@playwright/test", "node"]
  },
  "include": ["tests/**/*", "utils/**/*", "schemas/**/*", "bridge/**/*", "reporters/**/*"],
  "exclude": ["node_modules", "dist", "report-dashboard"]
}
